# Supabase Configuration (Frontend - Expo/React Native)
# Get these from: https://app.supabase.com/project/_/settings/api

# Supabase Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon/Public Key (safe to expose in client-side code)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps API Key (for outdoor exercise GPS tracking)
# Get from: https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Note: EXPO_PUBLIC_ prefix makes these available in the app
# The anon key is safe to expose - it's protected by Row Level Security (RLS)
