# Supabase Configuration (Root - for scripts and backend)
# Get these from: https://app.supabase.com/project/_/settings/api

# Supabase Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key (KEEP SECRET - has admin access)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Alternative naming (scripts support both)
HERCULES_SUPABASE_URL=https://your-project-id.supabase.co
HERCULES_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenRouter API Key (for Hercules AI edge function)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Development mode for AI (bypasses rate limits and credit checks)
# HERCULES_ENV=development
